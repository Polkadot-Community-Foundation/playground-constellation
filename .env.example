# Set to "1" to run with synthetic mock data instead of the live chain.
# Useful for developing/verifying the UI outside the Polkadot host container.
# When unset, the app connects through the host (getChainAPI) like playground-app.
VITE_USE_MOCK=

# Override the registry package name (defaults to @w3s/playground-registry).
VITE_PLAYGROUND_REGISTRY_PACKAGE=

# Set to "1" to connect directly to the chain over RPC (ASSET_HUB_WS in
# src/config.ts) instead of routing through the Polkadot host container. This is
# the production mode for the Summit kiosk (a gateway/plain-browser big screen,
# not necessarily inside the host) and is baked into the build via .env.production.
VITE_USE_DIRECT=

